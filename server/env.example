# PostgreSQL connection string (shared between local and Railway)
# Railway: Set this as a variable in Railway dashboard (auto-provided by PostgreSQL addon)
# Local: Copy this file to .env and set your DATABASE_URL
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
JWT_SECRET="change_me_please_very_secret"
PORT=5175
CORS_ORIGIN="http://localhost:5174"
# Admin user auto-created on startup (REQUIRED in production)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change_me_strong_password"
